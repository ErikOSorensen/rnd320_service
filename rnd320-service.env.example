# Serial port for the RND320 / KEL103
RND320_PORT=/dev/ttyACM0

# Baud rate (default 115200)
# RND320_BAUDRATE=115200

# HTTP bind address (default 0.0.0.0)
# RND320_HOST=0.0.0.0

# HTTP port (default 8320)
# RND320_HTTP_PORT=8320

# MQTT (optional — leave RND320_MQTT_BROKER unset to disable)
# RND320_MQTT_BROKER=localhost
# RND320_MQTT_PORT=1883
# RND320_MQTT_TOPIC=rnd320/measurements
# RND320_MQTT_INTERVAL=1.0
# RND320_MQTT_USERNAME=
# RND320_MQTT_PASSWORD=
